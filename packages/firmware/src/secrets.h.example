// Copy to `secrets.h` and fill in your values. `secrets.h` is gitignored.
//
// DEVICE_ID is the leading segment of every topic this node publishes —
// `backbar/<DEVICE_ID>/reading` etc. Pick a short, stable, lowercase slug.
// It must also match the `device_id` you register in `sensor_channel` on
// the server (see `POST /nodes/:device_id/channels`).
//
// Same secrets.h works for both supported boards — pick the env at build
// time with `pio run -e uno_r4_wifi` or `pio run -e esp32-s3-devkitc-1`.
// Channel→pin mapping is in main.cpp's `CHANNEL_PINS` array per board.

#pragma once

#define WIFI_SSID "your-ssid"
#define WIFI_PASS "your-password"

// Local Mosquitto on the home box.
#define MQTT_HOST "192.168.1.10"
#define MQTT_PORT 1883

#define DEVICE_ID "back-shelf-left"
#define FW_VERSION "0.1.0"
