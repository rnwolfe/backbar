# Backbar — environment template. Copy to .env (gitignored) and fill in.
# Never commit a real .env. AI key is bootstrapped per-host from ~/.ai_gateway_api_key.

# ─── AI (Vercel AI Gateway) ───────────────────────────────────────────────
# Bootstrap once: `cp $(<~/.ai_gateway_api_key) ...` then paste here.
AI_GATEWAY_API_KEY=

# ─── MQTT broker (P2 — fleet transport) ───────────────────────────────────
# Local Mosquitto, e.g. mqtt://localhost:1883
MQTT_URL=mqtt://localhost:1883

# ─── HTTP ingest HMAC (firmware + manual signing) ─────────────────────────
# Long random string; firmware signs payloads with this for X-Backbar-Sig.
HMAC_SECRET=

# ─── Webhook adapter (low-stock / node-offline alerts) ────────────────────
# Generic webhook — works for ntfy, Pushover, Discord, Slack.
WEBHOOK_URL=
WEBHOOK_METHOD=POST
# Optional JSON map of headers, e.g. {"Authorization":"Bearer xxx"}
WEBHOOK_HEADERS=
# Body template — {{bottle}} {{level_ml}} {{pct}} {{event}} substituted.
WEBHOOK_BODY_TEMPLATE=

# ─── Server ───────────────────────────────────────────────────────────────
PORT=8787
DATABASE_URL=./backbar.sqlite

# ─── Guest publish (snapshot mode → Vercel) ──────────────────────────────
VERCEL_TOKEN=
VERCEL_PROJECT_ID=

# ─── Optional: VA ABC procurement (deferred, P3+) ─────────────────────────
VA_ABC_ENABLED=false
