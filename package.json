{
  "name": "backbar",
  "private": true,
  "version": "0.8.0",
  "description": "Backbar — local-first home-bar OS: inventory + weight-based depletion + recipes + AI mixology",
  "workspaces": [
    "packages/core",
    "packages/db",
    "packages/server",
    "packages/operator-ui",
    "packages/guest-ui"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "release": "bun run scripts/release.ts",
    "release:dry-run": "bun run scripts/release.ts --dry-run",
    "corpus:build": "bun run scripts/build-flavor-corpus.ts",
    "test": "bun test",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/bun": "^1.1.13",
    "@ai-sdk/gateway": "^2.0.91",
    "ai": "^5.0.190",
    "zod": "^3.23.8"
  }
}
